{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test:audit-tamper-protection": "npm run build && node --test lib/tests/auditTamperProtection.test.js",
    "test:license-history": "npm run build && node --test lib/tests/licenseHistory.test.js",
    "test:override-logging": "npm run build && node --test lib/tests/overrideLogging.test.js",
    "test:audit-actions": "npm run build && node --test lib/tests/administrativeActionLogging.test.js",
    "test:audit-storage": "npm run build && node --test lib/tests/auditLogStorage.test.js",
    "test:search-token-index": "npm run build && node --test lib/tests/searchTokenIndex.test.js",
    "test:question-ingestion": "npm run build && node --test lib/tests/questionIngestion.test.js",
    "test:question-search-query": "npm run build && node --test lib/tests/questionSearchQuery.test.js",
    "test:tag-dictionary": "npm run build && node --test lib/tests/tagDictionary.test.js",
    "test:chapter-dictionary": "npm run build && node --test lib/tests/chapterDictionary.test.js",
    "test:audit": "npm run test:audit-storage && npm run test:audit-actions && npm run test:license-history && npm run test:override-logging && npm run test:audit-tamper-protection",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^11.10.1",
    "firebase-functions": "^4.4.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "typescript": "^5.7.3"
  },
  "private": true
}
