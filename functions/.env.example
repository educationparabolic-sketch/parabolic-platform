PROJECT_ID=parabolic-dev
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
EXAM_BASE_URL=http://localhost:4173
VENDOR_BASE_URL=http://localhost:6173
CDN_BASE_URL=https://cdn.yourdomain.com
QUESTION_ASSETS_BUCKET=parabolic-prod-question-assets
REPORTS_BUCKET=parabolic-prod-reports

# Local development secrets are loaded directly from environment variables.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
AI_API_KEY=
EMAIL_PROVIDER_KEY=

# Production secret references can be passed through environment variables.
# Values may be a secret ID (for the current project) or a full
# projects/<project>/secrets/<secret>/versions/<version> resource name.
STRIPE_SECRET_KEY_SECRET_NAME=STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET_NAME=STRIPE_WEBHOOK_SECRET
AI_API_KEY_SECRET_NAME=AI_API_KEY
EMAIL_PROVIDER_KEY_SECRET_NAME=EMAIL_PROVIDER_KEY
